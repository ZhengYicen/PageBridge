# ── LLM 配置 ──────────────────────────────────
# 默认使用 DeepSeek，在 .env 中设置 DEEPSEEK_API_KEY 即可
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# 如果想用其他模型，切换 provider 并设置对应 API KEY：
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
#
# LLM_PROVIDER=qwen
# QWEN_API_KEY=...
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 数据库 ────────────────────────────────────
# SQLite 默认，后续可切换 PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# ── 安全与多租户配置 ──────────────────────────

# 管理员引导（首次启动自动创建管理员账号）
# 如果不设置，系统启动后没有任何管理员账号，需要通过邀请码注册第一个用户
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=your_strong_admin_password

# 会话（天）
# SESSION_DAYS=30

# 生产环境应启用 Secure Cookie
# SESSION_COOKIE_SECURE=false

# CORS 允许的来源（逗号分隔）
# 开发环境：http://localhost:5173
# 生产环境：https://yourdomain.com
# ALLOWED_ORIGINS=http://localhost:5173

# ── 上传限制 ──────────────────────────────────
# 单文件大小上限（MB）
# MAX_UPLOAD_MB=100
# 每用户总存储上限（MB）
# MAX_USER_STORAGE_MB=500
# PDF 页数上限
# MAX_PDF_PAGES=1000

# EPUB 限制
# MAX_EPUB_FILES=10000        # EPUB 内最大文件数
# MAX_EPUB_UNCOMPRESSED_MB=500  # 解压后总大小上限
# MAX_EPUB_SINGLE_FILE_MB=50    # 单文件解压大小上限
# MAX_EPUB_COMPRESSION_RATIO=200 # 最大压缩比（防 ZIP Bomb）

# ── 翻译额度 ──────────────────────────────────
# 每用户每日翻译字符上限
# DAILY_TRANSLATION_CHARS=200000
# 每用户每月翻译字符上限
# MONTHLY_TRANSLATION_CHARS=2000000

# ── 并发限制 ──────────────────────────────────
# 每用户最大并发翻译任务数
# MAX_USER_TRANSLATE_JOBS=1
# 全站最大并发翻译任务数
# MAX_GLOBAL_TRANSLATE_JOBS=2

# ── 翻译重试 ──────────────────────────────────
# TRANSLATE_MAX_RETRIES=3
# TRANSLATE_RETRY_BACKOFF=2.0  # 指数退避基数（秒）
# TRANSLATE_API_TIMEOUT=120     # API 超时（秒）

# ── 解析限制 ──────────────────────────────────
# PARSE_TIMEOUT=600  # 解析超时（秒）

# ── 限流 ──────────────────────────────────────
# 简单进程内限流（多实例不共享）
# RATE_LIMIT_LOGIN=5      # 登录（次/分钟）
# RATE_LIMIT_REGISTER=3   # 注册（次/分钟）
# RATE_LIMIT_UPLOAD=10    # 上传（次/分钟）
# RATE_LIMIT_TRANSLATE=5  # 翻译（次/分钟）
# RATE_LIMIT_PARSE=3      # 解析（次/分钟）

# ── 其他 ──────────────────────────────────────
# API 文档（生产环境建议关闭）
# DOCS_ENABLED=true

# 安全响应头自定义
# SEC_HDR_XCTO=nosniff
# SEC_HDR_XFO=DENY
# SEC_HDR_XXSS=0
# SEC_HDR_REFERRER=strict-origin-when-cross-origin
